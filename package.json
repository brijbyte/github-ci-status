{
  "name": "github-ci-status",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.4",
  "publisher": "brijbyte",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brijbyte/github-ci-status.git"
  },
  "keywords": [
    "github",
    "ci",
    "status",
    "pull request",
    "checks"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "githubCiStatus.showChecks",
        "title": "%command.showChecks.title%",
        "icon": "$(checklist)"
      },
      {
        "command": "githubCiStatus.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "githubCiStatus.openPullRequest",
        "title": "%command.openPullRequest.title%",
        "icon": "$(github)"
      }
    ],
    "keybindings": [
      {
        "command": "githubCiStatus.refresh",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "githubCiStatus.autoRefreshIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "%configuration.autoRefreshIntervalSeconds.description%"
        },
        "githubCiStatus.githubApiBaseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "%configuration.githubApiBaseUrl.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write .",
    "lint": "eslint .",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "prettier": "prettier --check .",
    "test": "vitest run",
    "typescript": "tsc -p tsconfig.json --noEmit",
    "vscode:prepublish": "pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.19.0",
    "@types/vscode": "1.105.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.6"
  }
}
